# ============================================================================
# Caddyfile — origin 端反向代理 / 靜態檔伺服器(跑在 Oracle A1)
# ----------------------------------------------------------------------------
# 角色:Caddy 只聽 127.0.0.1:8080(不對外),作為 cloudflared 連入的唯一 origin,
#       依 Host 把請求分流到各站(靜態檔 / 反代後端)。
# 資料流:cloudflared → http://127.0.0.1:8080(本檔)→ file_server / reverse_proxy
#
# 為什麼 http:// + auto_https off:TLS 已在 Cloudflare 邊緣終結,Tunnel 內已加密,
#   origin 不需也不該再自簽憑證。http_port 8080 讓所有 http:// 站台改聽 8080。
# ============================================================================

{
	auto_https off
	http_port 8080          # http:// 站台改聽 8080(對上 cloudflared 轉發的 127.0.0.1:8080)
	admin localhost:2019
}

# --- 主站:terrychou.com → /srv/main 靜態檔 -------------------------------
http://terrychou.com {
	bind 127.0.0.1
	root * /srv/main
	encode zstd gzip
	file_server
	try_files {path} {path}/ /index.html
	respond /healthz 200
}

# --- live demo:soulshard.terrychou.com ------------------------------------
# 前端為純靜態遊戲(/srv/soulshard);後端 Soulshard-Hunter `server/`(Node+Fastify+
# Postgres)以 docker compose 跑在 127.0.0.1:8787,提供 REST(/api/*)與 co-op
# WebSocket(/rt)。
#
# ⚠️ 用 handle 區塊隔離:Caddy 的 try_files 屬 rewrite 階段、順序在 reverse_proxy
#    之前,若不隔離會把 /api/* 先改寫成 /index.html 而打不到後端。handle 群組互斥,
#    /api 與 /rt 命中 @backend 群組,其餘才進靜態群組(try_files 只作用於此)。
http://soulshard.terrychou.com {
	bind 127.0.0.1
	encode zstd gzip

	@backend path /api/* /rt /rt/*
	handle @backend {
		reverse_proxy 127.0.0.1:8787   # reverse_proxy 會自動處理 WebSocket upgrade
	}

	handle {
		root * /srv/soulshard
		file_server
		try_files {path} {path}/ /index.html
	}
}


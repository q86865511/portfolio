# ============================================================================
# 範例:未來「動態服務」用 reverse_proxy(非靜態檔)
# ----------------------------------------------------------------------------
# 例如某子站是 Next.js SSR / FastAPI / Node 服務,跑在本機某個 port。
# 這裡示範把 api.terrychou.com 反代到本機 :3001。實際啟用時記得同步:
#   1) cloudflared config.yml 加 ingress  2) 加 DNS CNAME
# ============================================================================
# http://api.terrychou.com {
# 	bind 127.0.0.1
# 	encode zstd gzip
#
# 	reverse_proxy 127.0.0.1:3001 {
# 		# 把原始 Host / 來源資訊帶給後端(後端若需要判斷網域 / 來源 IP 會用到)。
# 		header_up Host {host}
# 		header_up X-Forwarded-Proto {scheme}
#
# 		# 後端健康檢查(被動):連不上時短暫剔除,避免一直打死掉的後端。
# 		health_uri /healthz
# 		health_interval 10s
# 	}
# }
